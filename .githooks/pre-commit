#!/bin/sh
# Secrets-scan pre-commit hook (skeleton default).
# Blocks a commit if staged changes look like they contain credentials or an .env file.
# Activate per project:  git config core.hooksPath .githooks
# Bypass a false positive:  git commit --no-verify   (use sparingly)

fail=0

# 1. Never commit real env files (allow *.example / *.local.example).
staged_env=$(git diff --cached --name-only | grep -E '(^|/)\.env(\.[a-zA-Z0-9]+)?$' | grep -vE '\.example$')
if [ -n "$staged_env" ]; then
  echo "BLOCKED: attempting to commit env file(s):"
  echo "$staged_env" | sed 's/^/  - /'
  fail=1
fi

# 2. Scan staged text diff for high-signal secret patterns.
diff=$(git diff --cached -U0 --no-color)
patterns='sk-[A-Za-z0-9]{16,}|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|-----BEGIN (RSA|OPENSSH|EC|PGP) PRIVATE KEY-----|AIza[0-9A-Za-z_-]{20,}'
hits=$(printf '%s\n' "$diff" | grep -nE "^\+" | grep -E "$patterns")
if [ -n "$hits" ]; then
  echo "BLOCKED: possible secret(s) in staged changes:"
  printf '%s\n' "$hits" | sed 's/^/  /'
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "Move secrets to .env.local (gitignored). Re-run once removed, or use --no-verify if this is a confirmed false positive."
  exit 1
fi
exit 0
