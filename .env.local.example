# DigitalStudioz — Environment Configuration
# Copy to .env.local and fill in your values

# Mem0 — DigitalStudioz isolated memory collection
MEM0_USER_ID=digitalstudioz
MEM0_COLLECTION=digitalstudioz_memories
MEM0_LM_MODEL=qwen3-4b-instruct-2507
MEM0_JSON_SCHEMA=false

# Draven — AI assistant cross-session memory (shared across all profiles)
DRAVEN_USER_ID=draven
DRAVEN_COLLECTION=draven_memories

# Hermes profile
HERMES_PROFILE_NAME=DigitalStudioz
HERMES_PROFILE_SLUG=digitalstudioz

# Voice
DRAVEN_VOICE_POLICY=ritual
DRAVEN_VOICE_ERRORS=1

# Optional: Override LLM model for LiteLLM/DeepSeek
# HERMES_LM_MODEL=deepseek-v4-pro
