# DigitalStudioz — Environment Configuration
# Copy to .env.local:  copy .env.local.example .env.local
# Or run: npm run env:setup
# Full registry: .cursor/docs/ENV-VARS-REFERENCE.md
# NEVER commit .env.local

# =============================================================================
# Mem0 — DigitalStudioz isolated (REQUIRED — do not share with other profiles)
# =============================================================================
MEM0_USER_ID=digitalstudioz
MEM0_COLLECTION=digitalstudioz_memories
MEM0_QDRANT_PATH=%USERPROFILE%\.mem0\qdrant_digitalstudioz
MEM0_API_KEY=REPLACE_WITH_MEM0_API_KEY
MEM0_LM_MODEL=qwen3-4b-instruct-2507
MEM0_JSON_SCHEMA=false

# =============================================================================
# Draven — AI assistant cross-session (shared across all profiles)
# =============================================================================
DRAVEN_USER_ID=draven
DRAVEN_COLLECTION=draven_memories

# =============================================================================
# Hermes profile
# =============================================================================
HERMES_PROFILE_NAME=DigitalStudioz
HERMES_PROFILE_SLUG=digitalstudioz

# =============================================================================
# DeepSeek / LiteLLM (paid cloud — Hermes, Telegram, Cursor Agent)
# =============================================================================
DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_KEY
MSC_LITELLM_MASTER_KEY=REPLACE_WITH_LITELLM_MASTER_KEY
MSC_LITELLM_PORT=4000
MSC_LITELLM_START_NGROK=0
DISABLE_SCHEMA_UPDATE=true

# =============================================================================
# Ngrok (Cursor Agent HTTPS — set MSC_LITELLM_START_NGROK=1 or use session:start:full)
# =============================================================================
NGROK_AUTHTOKEN=REPLACE_WITH_NGROK_TOKEN

# =============================================================================
# LM Studio (free local / Mem0 inference)
# =============================================================================
LMSTUDIO_HOST=127.0.0.1
LMSTUDIO_PORT=1234
LMSTUDIO_MODEL=qwen3-4b-instruct-2507

# =============================================================================
# Telegram (two-way iPhone chat)
# =============================================================================
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID
TELEGRAM_ALLOWED_USERS=REPLACE_WITH_USER_IDS
TELEGRAM_HOME_CHANNEL=REPLACE_WITH_CHANNEL
TELEGRAM_TIMEZONE=America/Los_Angeles

# =============================================================================
# MCP servers (Cursor) — run npm run sync:mcp-env after filling these
# =============================================================================
GITHUB_PERSONAL_ACCESS_TOKEN=REPLACE_WITH_GITHUB_PAT
TAVILY_API_KEY=REPLACE_WITH_TAVILY_KEY
HOSTINGER_API_TOKEN=REPLACE_WITH_HOSTINGER_TOKEN
FAL_API_KEY=REPLACE_WITH_FAL_KEY
HF_TOKEN=REPLACE_WITH_HF_TOKEN
FIRECRAWL_API_KEY=REPLACE_WITH_FIRECRAWL_KEY

# =============================================================================
# Hostinger — shared account credentials + DigitalStudioz site paths
# =============================================================================
FTP_HOST=REPLACE_WITH_FTP_HOST
FTP_USERNAME=REPLACE_WITH_FTP_USER
FTP_PASSWORD=REPLACE_WITH_FTP_PASSWORD
FTP_PORT=21
FTP_REMOTE_PATH=/nodejs/digitalstudioz
HOSTINGER_SSH_HOST=REPLACE_WITH_SSH_HOST
HOSTINGER_SSH_PORT=65002
HOSTINGER_SSH_USER=REPLACE_WITH_SSH_USER
HOSTINGER_SSH_PASSWORD=REPLACE_WITH_SSH_PASSWORD
DIGITALSTUDIOZ_DOMAIN=digitalstudioz.dev
DIGITALSTUDIOZ_WEB_ROOT=REPLACE_WITH_REMOTE_WEB_ROOT
DIGITALSTUDIOZ_APP_ROOT=REPLACE_WITH_REMOTE_APP_ROOT
DIGITALSTUDIOZ_DEPLOY_METHOD=hostinger-node

# =============================================================================
# Voice (Draven — ritual only)
# =============================================================================
DRAVEN_VOICE=omnivoice
DRAVEN_VOICE_FALLBACK=edge
DRAVEN_VOICE_POLICY=ritual
DRAVEN_VOICE_ERRORS=1

# =============================================================================
# Backup
# =============================================================================
PROFILE_BACKUP_ROOT=G:\Hermes_Project_BackUpz\DigitalStudioz
